# PostgreSQL connection string.
#
# --- Supabase setup (read this carefully) ---
# Supabase offers THREE connection types.  Use the right one for each purpose:
#
#  1. Transaction pooler  port 6543  <- DO NOT use for DATABASE_URL on Render
#                                        (Alembic DDL migrations will fail)
#
#  2. Session pooler      port 5432  <- Recommended for DATABASE_URL.
#     URL format: postgres://postgres.[ref]:[password]@aws-X-region.pooler.supabase.com:5432/postgres?sslmode=require
#
#  3. Direct connection   port 5432  <- Also fine for DATABASE_URL or MIGRATION_DATABASE_URL.
#     URL format: postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require
#
# IMPORTANT: The default Supabase database name is "postgres" (not your project name).
# IMPORTANT: Passwords containing @ must be URL-encoded as %40.
#
# --- MIGRATION_DATABASE_URL ---
# If you must use the transaction pooler (port 6543) as DATABASE_URL,
# also set MIGRATION_DATABASE_URL to the session-pooler (port 5432) URL.
# Alembic will use MIGRATION_DATABASE_URL; the running app will use DATABASE_URL.
# If both point at the same URL (session pooler / direct), MIGRATION_DATABASE_URL
# can be left unset.

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fdpac
# MIGRATION_DATABASE_URL=  # set only when DATABASE_URL is the transaction pooler

# JWT signing secret.  Set EITHER JWT_SECRET or SECRET_KEY on Render — both are accepted.
JWT_SECRET=change-me
# SECRET_KEY=change-me  # alternative name accepted by the app

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins.
# On Render, set this to your Vercel deployment URL.
CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_PER_MINUTE=60
