# --- Neon DB setup (read this carefully) ---
# Neon offers optimized serverless PostgreSQL with connection pooling.
#
#  1. Pooler URL (recommended for DATABASE_URL)
#     Use the 'Pooled' connection string from the Neon dashboard.
#     URL format: postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/neondb?sslmode=require
#
#  2. Direct Connection (recommended for MIGRATION_DATABASE_URL)
#     Use the 'Direct' connection string (usually has ?options=endpoint%3D... or a different host).
#     This is REQUIRED for DDL/Alembic migrations.
#
# IMPORTANT: This app automatically enforces 'channel_binding=require' and 'sslmode=require'
# for all neon.tech connections to satisfy Neon security requirements.
#
# --- Supabase setup alternate ---
# If using Supabase, use port 5432 for session pooling/direct (MIGRATION_DATABASE_URL)
# and port 6543 for transaction pooling (DATABASE_URL).
#
# --- Database URLs ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fdpac
MIGRATION_DATABASE_URL=  # set to Direct Connection URL when DATABASE_URL is a pooler

# JWT signing secret.  Set EITHER JWT_SECRET or SECRET_KEY on Render — both are accepted.
JWT_SECRET=change-me
# SECRET_KEY=change-me  # alternative name accepted by the app

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins.
# On Render, set this to your Vercel deployment URL (include https://).
CORS_ORIGINS=http://localhost:3000,https://fdpac-frontend.vercel.app

RATE_LIMIT_PER_MINUTE=60
